# =========================
# Unity generated folders
# =========================
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
UserSettings/
MemoryCaptures/

# =========================
# Keep important Unity files
# =========================
!Assets/
!ProjectSettings/
!Packages/

# Keep meta files (VERY IMPORTANT)
!*.meta

# =========================
# XML handling (CUSTOM)
# =========================

# Ignore ALL xml files
*.xml

# BUT allow important XML inside Assets (if needed later)
!Assets/**/*.xml

# Ignore XML in unwanted places
Logs/*.xml
Temp/*.xml

# =========================
# IDE files
# =========================

# Visual Studio
.vs/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj

# Rider
.idea/

# VS Code
.vscode/

# =========================
# OS files
# =========================

# Windows
Thumbs.db
Desktop.ini

# macOS
.DS_Store

# =========================
# Unity cache / db files
# =========================
*.pidb
*.pdb
*.mdb
*.opendb
*.VC.db

# =========================
# Crash / logs
# =========================
sysinfo.txt
*.log

# =========================
# Builds / exports
# =========================
*.apk
*.aab
*.unitypackage

# =========================
# Addressables
# =========================
ServerData/

# =========================
# Backup files
# =========================
*.bak
*.backup
*.old
*.orig

# =========================
# Optional (StreamingAssets)
# =========================
# Assets/StreamingAssets/

# =========================
# DOTS / ECS
# =========================
*.entities
